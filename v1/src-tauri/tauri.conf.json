{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "CryptArtist Studio",
  "version": "1.69.420",
  "identifier": "com.cryptartist.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CryptArtist Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' tauri:; connect-src 'self' http://127.0.0.1:8080 http://localhost:8080 ws://localhost:1420; img-src 'self' blob: data: asset:; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "both",
        "languages": ["English"],
        "startMenuFolder": "CryptArtist Studio"
      }
    },
    "fileAssociations": [
      {
        "ext": ["CryptArt", "cryptart"],
        "mimeType": "application/x-cryptartist-art",
        "description": "CryptArtist Studio Project",
        "role": "Editor"
      },
      {
        "ext": ["Crypt", "crypt"],
        "mimeType": "application/x-cryptartist-crypt",
        "description": "CryptArtist Crypt Collection",
        "role": "Editor"
      }
    ]
  }
}
